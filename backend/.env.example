# HydroAI – Environment Configuration
# Copy this file to .env and fill in your own values.
# Never commit .env to version control.

# ── Database (SQLite for local dev, PostgreSQL for production) ────────────────
DATABASE_URL=sqlite+aiosqlite:///./hydroai.db

# ── App ───────────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:8000
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── ML Model ─────────────────────────────────────────────────────────────────
MODEL_PATH=models/model.pkl

# ── Risk thresholds ───────────────────────────────────────────────────────────
LOW_RISK_THRESHOLD=0.3
HIGH_RISK_THRESHOLD=0.6
SEVERE_RISK_THRESHOLD=0.8
FLOOD_DEPTH_THRESHOLD=0.3

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300

# ── MongoDB Atlas (required for auth, subscribers, site config) ───────────────
# Create a free cluster at https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/hydroai?retryWrites=true&w=majority
MONGO_DB_NAME=hydroai

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-random-64-char-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Gmail SMTP (for flood alert emails) ──────────────────────────────────────
# Enable 2FA on Gmail, then create an App Password at:
# myaccount.google.com → Security → 2-Step Verification → App passwords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
ALERT_FROM_NAME=HydroAI Flood Alerts
