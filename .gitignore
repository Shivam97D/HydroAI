# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
env/
.venv/
ENV/

# ── Environment / secrets (NEVER commit — copy .env.example instead) ──────────
.env
.env.*
!.env.example

# ── Databases ─────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Generated flood maps (regenerated at runtime per prediction) ──────────────
backend/maps/*.png
backend/maps/*.geojson

# ── DEM / elevation tile cache (auto-downloaded from Copernicus) ──────────────
backend/data/dem_cache/

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/build/
.npm

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Testing / coverage ────────────────────────────────────────────────────────
